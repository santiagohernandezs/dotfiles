###################
### ZSH ALIASES ###
###################
#
#
# This file is used to store aliases that are used by the shell.
# It is sourced by the shell when it starts up.
#
# General Aliases
# ---------------
alias cls="clear"
alias cat="bat"
alias top="btop"
alias tm="tmux"
alias sr="source ~/.config/zsh/.zshrc"
alias ld="lazydocker"
alias lg="lazygit"
alias ltm="lazy-tmux"
alias path="echo $PATH | tr ':' '\n' | bat"
alias hl="hledger -s"
alias clab="sudo containerlab"
#
# 
# Kanata Aliases
# -----------------
alias ks="systemctl start --user kanata"
alias kk="systemctl stop --user kanata"
#
# Aws Aliases
# ---------------
alias awslocal="aws --endpoint-url=http://localhost:4566 --profile dev"  # Use AWS CLI with LocalStack
#
# Yay Aliases
# ---------------
alias yup="yay -Syu --noconfirm"        # Update all packages without confirmation
alias yi="yay -S --noconfirm"          # Install a package without confirmation
alias yr="yay -Rns --noconfirm"        # Remove a package and its dependencies without confirmation
alias ycd="yay -Sc --noconfirm"         # Clean the package cache without confirmation
alias ys="yay -Ss"                     # Search for a package
#
#
# Pacman Aliases
# ----------------
alias pu="sudo pacman -Syu"             # Update all packages
alias pi="sudo pacman -S"               # Install a package
alias pr="sudo pacman -Rns"             # Remove a package and its dependencies
alias pcd="sudo pacman -Sc"             # Clean the package cache
alias pss="pacman -Ss"                   # Search for a package
#
# Suffix Aliases
# ---------------
alias -s ts="nvim"      # Open TypeScript files in Neovim
alias -s js="nvim"      # Open JavaScript files in Neovim
alias -s json="nvim"    # Open JSON files in Neovim
alias -s md="bat"       # Open Markdown files in Bat
alias -s yml="nvim"     # Open YAML files in Neovim
alias -s yaml="nvim"    # Open YAML files in Neovim
alias -s log="bat"      # Open Log files in Bat
alias -s conf="nvim"    # Open Config files in Neovim
alias -s toml="nvim"    # Open TOML files in Neovim
alias -s pdf="zathura"  # Open PDF files in Zathura
#
#
# Editor Aliases
# --------------
alias vi="nvim"                        # Open Neovim (Main Editor)
#
# File Management Aliases
# -----------------------
alias lh="eza -dl .* --icons --group-directories-first"
alias ll="eza -al --icons --group-directories-first"
alias ls="eza -alf --color-always --sort=size --icons"
alias lt="eza -al --icons --sort=modified"
